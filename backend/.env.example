# Database
DATABASE_URL=postgresql+asyncpg://readsound_user:readsound_pass@db:5432/readsound_db

# Redis
REDIS_URL=redis://redis:6379

# JWT
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Spotify OAuth
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/spotify/callback

# Google Books API (optional, enhances book search)
GOOGLE_BOOKS_API_KEY=your_google_books_api_key

# Frontend URL (for redirects after OAuth)
FRONTEND_URL=http://localhost:3000

# ML Model path
ML_MODELS_DIR=/app/ml_models
